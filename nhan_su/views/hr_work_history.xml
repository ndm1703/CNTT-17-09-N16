<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_work_history_tree" model="ir.ui.view">
            <field name="name">hr.work.history.tree</field>
            <field name="model">hr.work.history</field>
            <field name="arch" type="xml">
                <tree string="Work History">
                    <field name="company_name"/>
                    <field name="position"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="employee_id"/>
                </tree>
            </field>
        </record>

        <record id="view_hr_work_history_form" model="ir.ui.view">
            <field name="name">hr.work.history.form</field>
            <field name="model">hr.work.history</field>
            <field name="arch" type="xml">
                <form string="Work History">
                    <sheet>
                        <group>
                            <field name="employee_id"/>
                            <field name="company_name"/>
                            <field name="position"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- optional: embed as a notebook page on employee form -->
        <record id="view_employee_form_inherit_work_history" model="ir.ui.view">
            <field name="name">hr.employee.form.work.history</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Work History">
                        <field name="work_history_ids">
                            <tree editable="bottom">
                                <field name="company_name"/>
                                <field name="position"/>
                                <field name="date_start"/>
                                <field name="date_end"/>
                            </tree>
                            <form>
                                <group>
                                    <field name="company_name"/>
                                    <field name="position"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                </group>
                            </form>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
