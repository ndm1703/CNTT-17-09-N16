<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_danh_sach_chung_chi_bang_cap_form" model="ir.ui.view">
            <field name="name">danh_sach_chung_chi_bang_cap</field>
            <field name="model">danh_sach_chung_chi_bang_cap</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_read_only" style="font-size:25px">Danh sách chứng chỉ, bằng cấp</div>
                        <group col="4" string="Thông tin chung">
                            <field name="nhan_vien_id"/>
                            <field name="ma_dinh_danh"/>
                            <field name="chung_chi_bang_cap_id"/>
                            <field name="level_id"/>
                            <field name="phan_loai"/>
                            <field name="trang_thai" widget="badge"/>
                            <field name="ghi_chu"/>
                            <field name="ngay_cap"/>
                            <field name="ngay_het_han"/>
                            <field name="thoi_han_mac_dinh_thang" readonly="1"/>
                            <field name="noi_cap"/>
                            <field name="xep_loai"/>
                        </group>
                        <group string="Tệp đính kèm">
                            <field name="ten_tep_dinh_kem" invisible="1"/>
                            <field name="tep_dinh_kem" filename="ten_tep_dinh_kem"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_danh_sach_chung_chi_bang_cap_tree" model="ir.ui.view">
            <field name="name">danh_sach_chung_chi_bang_cap</field>
            <field name="model">danh_sach_chung_chi_bang_cap</field>
            <field name="arch" type="xml">
                <tree decoration-success="trang_thai == 'con_han'" decoration-danger="trang_thai == 'het_han'">
                    <field name="nhan_vien_id"/>
                    <field name="ma_dinh_danh"/>
                    <field name="chung_chi_bang_cap_id"/>
                    <field name="level_id"/>
                    <field name="phan_loai"/>
                    <field name="trang_thai" widget="badge"/>
                    <field name="ngay_cap"/>
                    <field name="ngay_het_han"/>
                    <field name="noi_cap"/>
                    <field name="xep_loai"/>
                    <field name="ghi_chu"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="danh_sach_chung_chi_bang_cap_search">
            <field name="model">danh_sach_chung_chi_bang_cap</field>
            <field name="arch" type="xml">
                <search>
                    <field name="nhan_vien_id"/>
                    <field name="ma_dinh_danh"/>
                    <field name="chung_chi_bang_cap_id"/>
                    <field name="level_id"/>
                    <field name="phan_loai"/>
                    <field name="trang_thai"/>
                    <field name="ngay_cap"/>
                    <field name="ngay_het_han"/>
                    <field name="noi_cap"/>
                    <field name="xep_loai"/>
                    <field name="ghi_chu"/>
                    <filter name="group_by_nhan_vien" string="Nhân viên" context="{'group_by': 'nhan_vien_id'}"/>
                    <filter name="group_by_phan_loai" string="Phân loại" context="{'group_by': 'phan_loai'}"/>
                    <filter name="group_by_level" string="Cấp độ" context="{'group_by': 'level_id'}"/>
                </search>
            </field>
        </record>

        <record id="action_danh_sach_chung_chi_bang_cap" model="ir.actions.act_window">
            <field name="name">Danh sách chứng chỉ bằng cấp</field>
            <field name="res_model">danh_sach_chung_chi_bang_cap</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_group_by_nhan_vien': 1}</field>
            <field name="search_view_id" ref = "danh_sach_chung_chi_bang_cap_search"/>
        </record>
    </data>
</odoo>
        
    
