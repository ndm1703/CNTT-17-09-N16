<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_form" model="ir.ui.view">
            <field name="name">nhan_vien</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_read_only" style="font-size:25px">Nhân viên</div>
                        <group col="4" string="Thông tin chung">
                            <field name="ho_ten_dem"/>
                            <field name="ten"/>
                            <field name="ho_va_ten"/>
                            <field name="ma_dinh_danh"/>
                            <field name="ngay_sinh"/>
                            <field name="tuoi"/>
                            <field name="so_ngay_cong_thang" readonly="1"/>
                            <field name="so_ngay_nghi_khong_phep_thang" readonly="1"/>
                            <field name="so_nguoi_bang_tuoi"/>
                            <field name="que_quan"/>
                            <field name="email"/>
                            <field name="anh" widget="image"/>
                        </group>
                        <notebook>
                            <page string="Danh sách lịch sử công tác">
                                <field name="lich_su_cong_tac_ids"/>
                            </page>
                            <page string="Danh sách chứng chỉ bằng cấp">
                                <field name="danh_sach_chung_chi_bang_cap_ids"/>
                            </page>
                            <page string="Hợp đồng">
                                <field name="hop_dong_ids">
                                    <tree editable="bottom">
                                        <field name="ma_hop_dong"/>
                                        <field name="chuc_vu_id"/>
                                        <field name="loai_hop_dong"/>
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="luong_co_ban"/>
                                        <field name="phu_cap"/>
                                        <field name="trang_thai" widget="badge"/>
                                    </tree>
                                    <form string="Hợp đồng nhân viên">
                                        <group col="4">
                                            <field name="ma_hop_dong"/>
                                            <field name="chuc_vu_id"/>
                                            <field name="loai_hop_dong"/>
                                            <field name="ngay_bat_dau"/>
                                            <field name="ngay_ket_thuc"/>
                                            <field name="luong_co_ban"/>
                                            <field name="phu_cap"/>
                                            <field name="trang_thai" widget="badge" readonly="1"/>
                                        </group>
                                        <group>
                                            <field name="ghi_chu"/>
                                        </group>
                                    </form>
                                </field>
                            </page>
                            <page string="Bảng lương">
                                <field name="bang_luong_ids">
                                    <tree editable="bottom">
                                        <field name="ma_bang_luong"/>
                                        <field name="hop_dong_id"/>
                                        <field name="thang"/>
                                        <field name="nam"/>
                                        <field name="luong_co_ban"/>
                                        <field name="phu_cap"/>
                                        <field name="thuong_tang_ca"/>
                                        <field name="thuong"/>
                                        <field name="khau_tru"/>
                                        <field name="phat_ve_som"/>
                                        <field name="tong_luong"/>
                                        <field name="trang_thai" widget="badge"/>
                                    </tree>
                                    <form string="Bảng lương nhân viên">
                                        <header>
                                            <button
                                                name="action_dong_bo_thuong_phat"
                                                string="Đồng bộ thưởng/phạt"
                                                type="object"
                                            />
                                            <button
                                                name="action_xac_nhan"
                                                string="Xác nhận"
                                                type="object"
                                                class="oe_highlight"
                                                attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"
                                            />
                                            <button
                                                name="action_thanh_toan"
                                                string="Thanh toán"
                                                type="object"
                                                class="oe_highlight"
                                                attrs="{'invisible': [('trang_thai', '!=', 'xac_nhan')]}"
                                            />
                                            <button
                                                name="action_dat_nhap"
                                                string="Đặt về nháp"
                                                type="object"
                                                attrs="{'invisible': [('trang_thai', '=', 'nhap')]}"
                                            />
                                            <field name="trang_thai" widget="statusbar" statusbar_visible="nhap,xac_nhan,da_thanh_toan"/>
                                        </header>
                                        <sheet>
                                            <group col="4">
                                                <field name="ma_bang_luong"/>
                                                <field name="hop_dong_id"/>
                                                <field name="thang"/>
                                                <field name="nam"/>
                                                <field name="luong_co_ban"/>
                                                <field name="phu_cap"/>
                                                <field name="so_ngay_cong_chuan"/>
                                                <field name="he_so_tang_ca"/>
                                                <field name="so_gio_tang_ca" readonly="1"/>
                                                <field name="he_so_phat_ve_som"/>
                                                <field name="so_gio_ve_som" readonly="1"/>
                                                <field name="thuong"/>
                                                <field name="thuong_tang_ca" readonly="1"/>
                                                <field name="khau_tru"/>
                                                <field name="phat_ve_som" readonly="1"/>
                                                <field name="so_ngay_phep_huong_luong" readonly="1"/>
                                                <field name="so_ngay_nghi_khong_luong" readonly="1"/>
                                                <field name="so_ngay_nghi_khong_phep" readonly="1"/>
                                                <field name="khau_tru_nghi_phep" readonly="1"/>
                                                <field name="tong_thuong" readonly="1"/>
                                                <field name="tong_phat" readonly="1"/>
                                                <field name="tong_luong" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="ghi_chu"/>
                                            </group>
                                            <group string="Quyết định liên kết">
                                                <field name="khen_thuong_xu_phat_ids" readonly="1">
                                                    <tree>
                                                        <field name="loai"/>
                                                        <field name="ten_su_kien"/>
                                                        <field name="ngay"/>
                                                        <field name="so_quyet_dinh"/>
                                                        <field name="so_tien"/>
                                                    </tree>
                                                </field>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Nghỉ phép">
                                <field name="nghi_phep_ids">
                                    <tree editable="bottom">
                                        <field name="ma_nghi_phep"/>
                                        <field name="loai_nghi_phep"/>
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="so_ngay_nghi"/>
                                        <field name="trang_thai" widget="badge"/>
                                    </tree>
                                    <form string="Nghỉ phép nhân viên">
                                        <header>
                                            <button
                                                name="action_gui_duyet"
                                                string="Gửi duyệt"
                                                type="object"
                                                class="oe_highlight"
                                                attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"
                                            />
                                            <button
                                                name="action_duyet"
                                                string="Duyệt"
                                                type="object"
                                                class="oe_highlight"
                                                attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"
                                            />
                                            <button
                                                name="action_tu_choi"
                                                string="Từ chối"
                                                type="object"
                                                attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"
                                            />
                                            <button
                                                name="action_dat_nhap"
                                                string="Đặt về nháp"
                                                type="object"
                                                attrs="{'invisible': [('trang_thai', '=', 'nhap')]}"
                                            />
                                            <field name="trang_thai" widget="statusbar" statusbar_visible="nhap,cho_duyet,da_duyet,tu_choi"/>
                                        </header>
                                        <sheet>
                                            <group col="4">
                                                <field name="ma_nghi_phep"/>
                                                <field name="loai_nghi_phep"/>
                                                <field name="ngay_bat_dau"/>
                                                <field name="ngay_ket_thuc"/>
                                                <field name="so_ngay_nghi" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="ly_do"/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Chấm công">
                                <field name="cham_cong_ids">
                                    <tree editable="bottom">
                                        <field name="ma_cham_cong"/>
                                        <field name="ngay_cham_cong"/>
                                        <field name="gio_vao_chuan"/>
                                        <field name="gio_ra_chuan"/>
                                        <field name="gio_vao"/>
                                        <field name="gio_ra"/>
                                        <field name="so_gio_lam_viec"/>
                                        <field name="so_phut_di_muon"/>
                                        <field name="so_phut_ve_som"/>
                                        <field name="so_phut_tang_ca"/>
                                        <field name="trang_thai" widget="badge"/>
                                    </tree>
                                    <form string="Chấm công nhân viên">
                                        <sheet>
                                            <group col="4">
                                                <field name="ma_cham_cong"/>
                                                <field name="ngay_cham_cong"/>
                                                <field name="gio_vao_chuan"/>
                                                <field name="gio_ra_chuan"/>
                                                <field name="gio_vao"/>
                                                <field name="gio_ra"/>
                                                <field name="so_gio_lam_viec" readonly="1"/>
                                                <field name="so_phut_di_muon" readonly="1"/>
                                                <field name="so_phut_ve_som" readonly="1"/>
                                                <field name="so_phut_tang_ca" readonly="1"/>
                                                <field name="trang_thai"/>
                                            </group>
                                            <group>
                                                <field name="ghi_chu"/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    
                </form>
            </field>
        </record>

        <record id="view_nhan_vien_tree" model="ir.ui.view">
            <field name="name">nhan_vien</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <tree default_order="ho_va_ten">
                    <field name="ma_dinh_danh"/>
                    <field name="ho_ten_dem"/>
                    <field name="ten"/>
                    <field name="ho_va_ten"/>
                    <field name="ngay_sinh"/>
                    <field name="tuoi"/>
                    <field name="so_nguoi_bang_tuoi"/>
                    <field name="que_quan"/>
                    <field name="email"/>
                </tree>
            </field>
        </record>

        <record id="view_nhan_vien_kanban" model="ir.ui.view">
            <field name="name">nhan_vien.kanban</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <kanban default_group_by="que_quan">
                    <field name="ho_va_ten"/>
                    <field name="ma_dinh_danh"/>
                    <field name="tuoi"/>
                    <field name="que_quan"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="o_kanban_record_top">
                                <field name="ho_va_ten"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div>
                                    <strong>ID</strong>: <field name="ma_dinh_danh"/>
                                </div>
                                <div>
                                    <strong>Tuổi</strong>: <field name="tuoi"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record model="ir.ui.view" id="nhan_vien_search">
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_dinh_danh"/>
                    <field name="ho_va_ten"/>
                    <field name="ngay_sinh"/>
                    <field name="tuoi"/>
                    <field name="que_quan"/>
                    <field name="email"/>
                    <filter name="filter_que_quan" string="Có quê quán" domain="[('que_quan','!=',False)]"/>
                    <filter name="filter_tuoi_senior" string="Tuổi >= 35" domain="[('tuoi','>=',35)]"/>
                    <filter name="filter_tuoi_young" string="Tuổi &lt; 35" domain="[('tuoi','&lt;',35)]"/>
                </search>
            </field>
        </record>

        <record id="action_nhan_vien" model="ir.actions.act_window">
            <field name="name">Nhân viên</field>
            <field name="res_model">nhan_vien</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="search_view_id" ref = "nhan_vien_search"/>
        </record>
    </data>
</odoo>
        
    
