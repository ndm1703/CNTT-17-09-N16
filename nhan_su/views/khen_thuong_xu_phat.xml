<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_khen_thuong_xu_phat_tree" model="ir.ui.view">
        <field name="name">khen.thuong.xu.phat.tree</field>
        <field name="model">khen_thuong_xu_phat</field>
        <field name="arch" type="xml">
            <tree
                string="Khen thưởng/Xử phạt"
                decoration-success="loai == 'khen_thuong'"
                decoration-danger="loai == 'xu_phat'"
            >
                <field name="loai"/>
                <field name="ten_su_kien"/>
                <field name="ngay"/>
                <field name="so_quyet_dinh"/>
                <field name="nhan_vien_id"/>
                <field name="nhan_su_id"/>
                <field name="bang_luong_id"/>
                <field name="so_tien" sum="Tổng tiền"/>
            </tree>
        </field>
    </record>
    <record id="view_khen_thuong_xu_phat_form" model="ir.ui.view">
        <field name="name">khen.thuong.xu.phat.form</field>
        <field name="model">khen_thuong_xu_phat</field>
        <field name="arch" type="xml">
            <form string="Khen thưởng/Xử phạt">
                <sheet>
                    <group>
                        <field name="loai"/>
                        <field name="ten_su_kien"/>
                        <field name="ngay"/>
                        <field name="so_quyet_dinh"/>
                        <field name="nhan_vien_id"/>
                        <field name="nhan_su_id"/>
                        <field name="bang_luong_id" readonly="1"/>
                        <field name="so_tien"/>
                        <field name="currency_id"/>
                        <field name="noi_dung"/>
                        <field name="ghi_chu"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_khen_thuong_xu_phat" model="ir.actions.act_window">
        <field name="name">Khen thưởng/Xử phạt</field>
        <field name="res_model">khen_thuong_xu_phat</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_khen_thuong_xu_phat_root" name="Khen thưởng/Xử phạt" parent="hr.menu_hr_root" action="action_khen_thuong_xu_phat" sequence="100"/>
</odoo>
