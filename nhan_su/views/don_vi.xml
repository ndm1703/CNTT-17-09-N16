<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_don_vi_form" model="ir.ui.view">
            <field name="name">don_vi</field>
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_read_only" style="font-size:25px">Đơn vị</div>
                        <group col="4" string="Thông tin chung">
                            <field name="ma_don_vi"/>
                            <field name="ten_don_vi"/>
                            <field name="truong_bo_phan_id"/>
                            <field name="don_vi_cap_tren_id"/>
                            <field name="hr_department_id"/>
                            <field name="so_luong_nhan_vien" readonly="1"/>
                            <field name="so_vi_tri_tuyen_dung" readonly="1"/>
                            <field name="so_ung_vien" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Chức vụ">
                                <field name="chuc_vu_ids">
                                    <tree editable="bottom">
                                        <field name="ma_chuc_vu"/>
                                        <field name="ten_chuc_vu"/>
                                        <field name="cap_bac"/>
                                        <field name="muc_luong_co_ban"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Lịch sử công tác">
                                <field name="lich_su_cong_tac_ids" readonly="1">
                                    <tree>
                                        <field name="nhan_vien_id"/>
                                        <field name="chuc_vu_id"/>
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="trang_thai"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Vị trí tuyển dụng">
                                <field name="vi_tri_tuyen_dung_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="department_id"/>
                                        <field name="no_of_recruitment"/>
                                        <field name="expected_employees"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Ứng viên">
                                <field name="ung_vien_ids" readonly="1">
                                    <tree>
                                        <field name="partner_name"/>
                                        <field name="job_id"/>
                                        <field name="stage_id"/>
                                        <field name="department_id"/>
                                        <field name="ai_fit_level"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_don_vi_tree" model="ir.ui.view">
            <field name="name">don_vi</field>
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_don_vi"/>
                    <field name="ten_don_vi"/>
                    <field name="truong_bo_phan_id"/>
                    <field name="don_vi_cap_tren_id"/>
                    <field name="hr_department_id"/>
                    <field name="so_luong_nhan_vien"/>
                    <field name="so_vi_tri_tuyen_dung"/>
                    <field name="so_ung_vien"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="don_vi_search">
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_don_vi"/>
                    <field name="ten_don_vi"/>
                    <field name="truong_bo_phan_id"/>
                    <field name="don_vi_cap_tren_id"/>
                    <field name="hr_department_id"/>
                </search>
            </field>
        </record>

        <record id="action_don_vi" model="ir.actions.act_window">
            <field name="name">Đơn vị</field>
            <field name="res_model">don_vi</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref = "don_vi_search"/>
        </record>
    </data>
</odoo>
        
    
