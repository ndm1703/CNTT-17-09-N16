<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_cham_cong_nhan_vien_form" model="ir.ui.view">
            <field name="name">cham_cong_nhan_vien.form</field>
            <field name="model">cham_cong_nhan_vien</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group col="4" string="Thông tin chung">
                            <field name="ma_cham_cong"/>
                            <field name="nhan_vien_id"/>
                            <field name="ngay_cham_cong"/>
                            <field name="trang_thai"/>
                            <field name="gio_vao_chuan"/>
                            <field name="gio_ra_chuan"/>
                            <field name="gio_vao"/>
                            <field name="gio_ra"/>
                            <field name="so_gio_lam_viec" readonly="1"/>
                            <field name="so_phut_di_muon" readonly="1"/>
                            <field name="so_phut_ve_som" readonly="1"/>
                            <field name="so_phut_tang_ca" readonly="1"/>
                        </group>
                        <group string="Ghi chú">
                            <field name="ghi_chu" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_cham_cong_nhan_vien_tree" model="ir.ui.view">
            <field name="name">cham_cong_nhan_vien.tree</field>
            <field name="model">cham_cong_nhan_vien</field>
            <field name="arch" type="xml">
                <tree default_order="ngay_cham_cong desc">
                    <field name="ma_cham_cong"/>
                    <field name="nhan_vien_id"/>
                    <field name="ngay_cham_cong"/>
                    <field name="gio_vao_chuan"/>
                    <field name="gio_ra_chuan"/>
                    <field name="gio_vao"/>
                    <field name="gio_ra"/>
                    <field name="so_gio_lam_viec"/>
                    <field name="so_phut_di_muon"/>
                    <field name="so_phut_ve_som"/>
                    <field name="so_phut_tang_ca"/>
                    <field name="trang_thai" widget="badge"/>
                </tree>
            </field>
        </record>

        <record id="view_cham_cong_nhan_vien_search" model="ir.ui.view">
            <field name="name">cham_cong_nhan_vien.search</field>
            <field name="model">cham_cong_nhan_vien</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_cham_cong"/>
                    <field name="nhan_vien_id"/>
                    <field name="ngay_cham_cong"/>
                    <field name="trang_thai"/>
                    <filter name="co_mat" string="Có mặt" domain="[('trang_thai','=','co_mat')]"/>
                    <filter name="di_muon" string="Đi muộn" domain="[('trang_thai','=','di_muon')]"/>
                    <filter name="ve_som" string="Về sớm" domain="[('trang_thai','=','ve_som')]"/>
                    <filter name="nghi_phep" string="Nghỉ phép" domain="[('trang_thai','=','nghi_phep')]"/>
                    <filter name="nghi_khong_phep" string="Nghỉ không phép" domain="[('trang_thai','=','nghi_khong_phep')]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter name="group_nhan_vien" string="Nhân viên" context="{'group_by': 'nhan_vien_id'}"/>
                        <filter name="group_trang_thai" string="Trạng thái" context="{'group_by': 'trang_thai'}"/>
                        <filter name="group_ngay" string="Ngày" context="{'group_by': 'ngay_cham_cong'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_cham_cong_nhan_vien" model="ir.actions.act_window">
            <field name="name">Chấm công</field>
            <field name="res_model">cham_cong_nhan_vien</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_cham_cong_nhan_vien_search"/>
        </record>
    </data>
</odoo>
