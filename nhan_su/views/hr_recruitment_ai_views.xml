<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_job_form_ai_scan" model="ir.ui.view">
            <field name="name">hr.job.form.ai.scan</field>
            <field name="model">hr.job</field>
            <field name="inherit_id" ref="hr.view_hr_job_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='department_id']" position="after">
                    <field name="don_vi_id"/>
                </xpath>
                <xpath expr="//field[@name='description']" position="after">
                    <field name="ai_tieu_chi_tuyen_dung" placeholder="Ví dụ: python, sql, giao tiếp, quản lý dự án..."/>
                    <button
                        name="action_goi_y_tieu_chi_ai"
                        string="Gợi ý tiêu chí AI"
                        type="object"
                        class="oe_link"
                    />
                </xpath>
            </field>
        </record>

        <record id="view_hr_applicant_tree_ai_scan" model="ir.ui.view">
            <field name="name">hr.applicant.tree.ai.scan</field>
            <field name="model">hr.applicant</field>
            <field name="inherit_id" ref="hr_recruitment.crm_case_tree_view_job"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='department_id']" position="after">
                    <field name="don_vi_id" optional="show"/>
                </xpath>
                <xpath expr="//field[@name='stage_id']" position="after">
                    <field name="ai_match_score" optional="show"/>
                    <field name="ai_fit_level" optional="show"/>
                </xpath>
            </field>
        </record>

        <record id="view_hr_applicant_search_ai_scan" model="ir.ui.view">
            <field name="name">hr.applicant.search.ai.scan</field>
            <field name="model">hr.applicant</field>
            <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_search_bis"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='department_id']" position="after">
                    <field name="don_vi_id"/>
                </xpath>
                <xpath expr="//filter[@name='last_stage_update']" position="after">
                    <filter string="Mức độ phù hợp AI" name="group_ai_fit_level" context="{'group_by': 'ai_fit_level'}"/>
                    <filter string="Theo đơn vị" name="group_don_vi" context="{'group_by': 'don_vi_id'}"/>
                </xpath>
                <xpath expr="//filter[@name='blocked']" position="after">
                    <filter string="AI phù hợp cao" name="ai_high_match" domain="[('ai_fit_level', '=', 'high')]"/>
                </xpath>
            </field>
        </record>

        <record id="view_hr_applicant_form_ai_scan" model="ir.ui.view">
            <field name="name">hr.applicant.form.ai.scan</field>
            <field name="model">hr.applicant</field>
            <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button
                        name="action_ai_scan_for_job"
                        string="AI quét theo vị trí"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': [('job_id', '=', False)]}"
                    />
                    <button
                        name="action_tiep_nhan_nhan_vien"
                        string="Tiếp nhận nhân viên"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': [('nhan_vien_id', '!=', False)]}"
                    />
                    <button
                        name="action_xem_nhan_vien_lien_ket"
                        string="Mở hồ sơ nhân viên"
                        type="object"
                        attrs="{'invisible': [('nhan_vien_id', '=', False)]}"
                    />
                </xpath>
                <xpath expr="//field[@name='department_id']" position="after">
                    <field name="don_vi_id"/>
                    <field name="ngay_sinh"/>
                    <field name="nhan_vien_id" readonly="1"/>
                </xpath>
                <xpath expr="//field[@name='company_id']/ancestor::group[1]" position="after">
                    <group string="CV ứng viên">
                        <field name="cv_filename" invisible="1"/>
                        <field name="cv_file" filename="cv_filename"/>
                        <field name="cv_extracted_text" readonly="1" attrs="{'invisible': [('cv_extracted_text', '=', False)]}"/>
                    </group>
                </xpath>
                <xpath expr="//field[@name='company_id']/ancestor::group[1]" position="after">
                    <group string="AI đánh giá">
                        <field name="ai_match_score" readonly="1"/>
                        <field name="ai_fit_level" readonly="1"/>
                        <field name="ai_diem_manh" readonly="1"/>
                        <field name="ai_diem_yeu" readonly="1"/>
                        <field name="ai_last_scan" readonly="1"/>
                        <field name="ai_scan_summary" readonly="1"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
