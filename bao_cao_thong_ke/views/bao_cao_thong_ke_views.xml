<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bao_cao_thong_ke_search" model="ir.ui.view">
            <field name="name">bao.cao.thong.ke.search</field>
            <field name="model">bao_cao.thong_ke</field>
            <field name="arch" type="xml">
                <search string="Báo cáo thống kê">
                    <field name="vi_tri_id"/>
                    <field name="month"/>
                    <filter name="filter_has_interview" string="Có phỏng vấn" domain="[('interview_total','&gt;',0)]"/>
                </search>
            </field>
        </record>

        <record id="view_bao_cao_thong_ke_tree" model="ir.ui.view">
            <field name="name">bao.cao.thong.ke.tree</field>
            <field name="model">bao_cao.thong_ke</field>
            <field name="arch" type="xml">
                <tree string="Báo cáo thống kê tuyển dụng">
                    <field name="name"/>
                    <field name="month"/>
                    <field name="vi_tri_id"/>
                    <field name="candidate_count"/>
                    <field name="average_score"/>
                    <field name="interview_total"/>
                    <field name="interview_scheduled"/>
                    <field name="interview_done"/>
                    <field name="interview_cancelled"/>
                </tree>
            </field>
        </record>

        <record id="view_bao_cao_thong_ke_graph" model="ir.ui.view">
            <field name="name">bao.cao.thong.ke.graph</field>
            <field name="model">bao_cao.thong_ke</field>
            <field name="arch" type="xml">
                <graph string="Ứng viên theo tháng" type="bar" sample="1">
                    <field name="month" type="row"/>
                    <field name="candidate_count" type="measure"/>
                    <field name="vi_tri_id"/>
                </graph>
            </field>
        </record>

        <record id="view_bao_cao_thong_ke_pivot" model="ir.ui.view">
            <field name="name">bao.cao.thong.ke.pivot</field>
            <field name="model">bao_cao.thong_ke</field>
            <field name="arch" type="xml">
                <pivot string="Pivot thống kê tuyển dụng" sample="1">
                    <field name="month" type="row" interval="month"/>
                    <field name="vi_tri_id" type="col"/>
                    <field name="candidate_count" type="measure"/>
                    <field name="interview_total" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_bao_cao_thong_ke" model="ir.actions.act_window">
            <field name="name">Báo cáo chi tiết tuyển dụng</field>
            <field name="res_model">bao_cao.thong_ke</field>
            <field name="view_mode">tree,graph,pivot</field>
            <field name="search_view_id" ref="view_bao_cao_thong_ke_search"/>
        </record>

        <record id="menu_bao_cao_thong_ke" model="ir.ui.menu">
            <field name="name">Báo cáo tuyển dụng</field>
            <field name="parent_id" ref="ung_vien.menu_ung_vien_thong_ke"/>
            <field name="sequence">1</field>
        </record>

        <menuitem id="menu_bao_cao_thong_ke_chi_tiet" name="Báo cáo chi tiết" parent="menu_bao_cao_thong_ke" action="action_bao_cao_thong_ke" sequence="1"/>
    </data>
</odoo>
