<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_qlkh_khach_hang" model="ir.sequence">
            <field name="name">QLKH Khach Hang</field>
            <field name="code">qlkh.khach_hang</field>
            <field name="prefix">KH</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_qlkh_hop_dong" model="ir.sequence">
            <field name="name">QLKH Hop Dong</field>
            <field name="code">qlkh.hop_dong</field>
            <field name="prefix">HDKH/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
