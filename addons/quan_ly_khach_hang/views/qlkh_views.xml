<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <menuitem id="qlkh_menu_root" name="QLKH" sequence="1"/>

        <record id="view_qlkh_khach_hang_search" model="ir.ui.view">
            <field name="name">qlkh.khach_hang.search</field>
            <field name="model">qlkh.khach_hang</field>
            <field name="arch" type="xml">
                <search string="Khách hàng">
                    <field name="ma_khach_hang"/>
                    <field name="ten_khach_hang"/>
                    <field name="email"/>
                    <field name="so_dien_thoai"/>
                    <field name="ten_cong_ty"/>
                    <filter name="filter_dang_hoat_dong" string="Đang hoạt động" domain="[('trang_thai', '=', 'dang_hoat_dong')]"/>
                    <filter name="filter_moi" string="Mới" domain="[('trang_thai', '=', 'moi')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_loai_khach" string="Loại khách hàng" context="{'group_by': 'loai_khach_hang'}"/>
                        <filter name="group_muc_thu_nhap" string="Mức thu nhập" context="{'group_by': 'muc_thu_nhap'}"/>
                        <filter name="group_trang_thai" string="Trạng thái" context="{'group_by': 'trang_thai'}"/>
                    </group>
                    <searchpanel>
                        <field name="loai_khach_hang" string="Loại khách hàng"/>
                        <field name="muc_thu_nhap" string="Mức thu nhập"/>
                        <field name="trang_thai" string="Trạng thái"/>
                        <field name="gioi_tinh" string="Giới tính"/>
                        <field name="nhom_do_tuoi" string="Nhóm độ tuổi"/>
                    </searchpanel>
                </search>
            </field>
        </record>

        <record id="view_qlkh_khach_hang_tree" model="ir.ui.view">
            <field name="name">qlkh.khach_hang.tree</field>
            <field name="model">qlkh.khach_hang</field>
            <field name="arch" type="xml">
                <tree string="Khách hàng" default_order="ma_khach_hang">
                    <field name="ma_khach_hang"/>
                    <field name="ten_khach_hang"/>
                    <field name="email"/>
                    <field name="so_dien_thoai"/>
                    <field name="dia_chi"/>
                    <field name="loai_khach_hang"/>
                    <field name="muc_thu_nhap"/>
                    <field name="ten_cong_ty"/>
                    <field name="trang_thai"/>
                    <field name="tong_so_don_hang"/>
                </tree>
            </field>
        </record>

        <record id="view_qlkh_khach_hang_form" model="ir.ui.view">
            <field name="name">qlkh.khach_hang.form</field>
            <field name="model">qlkh.khach_hang</field>
            <field name="arch" type="xml">
                <form string="Khách hàng">
                    <sheet>
                        <group col="4">
                            <field name="ma_khach_hang"/>
                            <field name="ten_khach_hang"/>
                            <field name="email"/>
                            <field name="so_dien_thoai"/>
                            <field name="dia_chi"/>
                            <field name="loai_khach_hang"/>
                            <field name="muc_thu_nhap"/>
                            <field name="gioi_tinh"/>
                            <field name="ngay_sinh"/>
                            <field name="nhom_do_tuoi" readonly="1"/>
                            <field name="ten_cong_ty"/>
                            <field name="trang_thai"/>
                            <field name="tong_so_don_hang" readonly="1"/>
                            <field name="tong_giao_dich" readonly="1"/>
                        </group>
                        <group string="Ghi chú tổng quan">
                            <field name="ghi_chu_tong_quan"/>
                        </group>
                        <notebook>
                            <page string="Cơ hội"><field name="co_hoi_ids"/></page>
                            <page string="Tương tác"><field name="tuong_tac_ids"/></page>
                            <page string="Hợp đồng"><field name="hop_dong_ids"/></page>
                            <page string="Lịch sử giao dịch"><field name="giao_dich_ids"/></page>
                            <page string="Ghi chú"><field name="ghi_chu_ids"/></page>
                            <page string="Phản hồi"><field name="phan_hoi_ids"/></page>
                            <page string="Nhiệm vụ"><field name="nhiem_vu_ids"/></page>
                            <page string="Marketing"><field name="marketing_ids"/></page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_qlkh_khach_hang" model="ir.actions.act_window">
            <field name="name">Khách hàng</field>
            <field name="res_model">qlkh.khach_hang</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_qlkh_khach_hang_search"/>
        </record>

