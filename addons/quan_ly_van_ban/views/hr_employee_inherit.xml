<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- smart button on employee form to list the documents that employee is handling -->
    <record id="view_employee_form_inherit_van_ban" model="ir.ui.view">
        <field name="name">hr.employee.form.vanban</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_van_ban_phu_trach"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file">
                    <field name="van_ban_count" widget="statinfo"/>
                    <div class="o_stat_text">Văn bản</div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
